    if "timing" in user_input or "hours" in user_input:
        return "Our institute is open from 9 AM to 6 PM, Monday to Saturday."

    elif "fee" in user_input or "fees" in user_input or "cost" in user_input:
        return "The course fee is INR 1,25,000 for each semester."

