        return "You can reach us at +91 98233 56929 or email info@sitnagpur.siu.edu.in."

    elif "location" in user_input or "address" in user_input:
        return "We are located at Mouza - Wathoda, Nagpur - 440008, Maharashtra, India, India."

    elif "courses" in user_input or "programs" in user_input:
        return "We offer courses in Undergraduate Program in computer science and engineering and specialization courses in Artificial Intelligence and Data Science."

    elif "admission" in user_input or "enroll" in user_input:
        return "Admissions are open year-round. You can apply online via our website."

